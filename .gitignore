# ── Dependencies ───────────────────────────────────────────────────────
node_modules/

# ── Build output ───────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Runtime / per-machine app state ────────────────────────────────────
# All of .mantle/ is per-machine: config (with API keys), sessions,
# Englyph cache, cron DB, attachments.
.mantle/
mantle.pid
*.log

# ── Environment / secrets ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Per-agent companion workspaces ─────────────────────────────────────
# Personal content (USER, MEMORY, SOUL, IDENTITY, persona quotes) lives
# here. Use templates/agent-workspace/ as the scaffold for new agents.
/workspaces/
/references/

# ── Reference clones ────────────
/reference/

# ── Skills (application content, not core code) ────────────────────────
# Skill packs are per-deployment — they often hard-code endpoints,
# device inventories, companion-app coupling, etc. The skills *system*
# (src/skills/) ships and the deck-assist builder skills (assist-skills/)
# ship; individual agent SKILL.md packs do not.
/skills/
/voices/*

# ── Local model runtime + GGUF weights ─────────────────────────────────
# Per-machine + huge: the llama.cpp binary (platform/GPU-specific) lives in
# local/bin/, downloaded GGUF weights in local/models/, and registry.json
# tracks them. `mantle pull` populates this. None of it is project-shared.
# Anchored to the repo root with a leading slash so this does NOT also match
# src/local/ — the local-model SOURCE code, which must stay tracked.
/local/

# ── Per-machine Claude Code state ──────────────────────────────────────
# Local permissions, scheduled-task locks, etc. Not project-shared.
.claude/

# ── Playwright MCP debug snapshots ─────────────────────────────────────
.playwright-mcp/

# ── Rogue literal "~" dir ──────────────────────────────────────────────
# Created when a shell command didn't expand "~" (e.g. mkdir ~/foo in a
# context that took it literally). Should never be committed.
~/

# ── Project-level CLAUDE.md ────────────────────────────────────────────
# Auto-generated by Claude Code's /init skill — kept local.
/CLAUDE.md

# ── Scratch reorientation doc (in-progress provider refactor) ──────────
# Working notes read after a context compaction; delete when the rebuild
# is done.
/REORIENT.md

# ── Python venv + caches ───────────────────────────────────────────────
# The optional Englyph memory engine (pip package `englyph`) is hosted in
# a local venv at .venv/ when installed.
.venv/
__pycache__/
*.pyc
*.egg-info/

# ── OS / editor noise ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Debug screenshots at repo root
/*.png
