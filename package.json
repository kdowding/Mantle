{
  "name": "rev-mantle",
  "version": "0.1.0",
  "description": "rev://MANTLE — Lightweight agent harness",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kdowding/Mantle.git"
  },
  "bugs": {
    "url": "https://github.com/kdowding/Mantle/issues"
  },
  "homepage": "https://github.com/kdowding/Mantle#readme",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/cli.ts start",
    "stop": "bun run src/cli.ts stop",
    "restart": "bun run src/cli.ts restart",
    "status": "bun run src/cli.ts status",
    "test": "bun test",
    "test:providers": "bun run src/test-providers.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check:arch": "bun run scripts/check-arch.ts",
    "ui:dev": "vite ui",
    "ui:build": "vite build ui",
    "check:svelte": "cd ui && svelte-check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@modelcontextprotocol/server-brave-search": "^0.6.2",
    "@octokit/rest": "^22.0.1",
    "@playwright/mcp": "^0.0.78",
    "chrono-node": "^2.10.0",
    "croner": "^10.0.1",
    "openai": "^6.48.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/bun": "^1.3.14",
    "oxlint": "^1.74.0",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "typescript": "^5.7.0",
    "vite": "^8.1.5"
  }
}
