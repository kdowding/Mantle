# rev://MANTLE — environment variables
#
# Copy this file to `.env` and fill in the keys you have. Bun auto-loads
# `.env` at startup. Env keys are a FALLBACK: a key set in-app (Settings →
# Providers) or in `.mantle/config.json` wins; env fills only providers you
# haven't set there. `.env` is gitignored; `.env.example` is the template.

# ── Providers (at least one required) ──────────────────────────────────

# Anthropic API key — used by the Claude provider.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — used by the ChatGPT provider.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# xAI API key — used by the Grok provider.
# https://x.ai/api
XAI_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────

# Kie.ai API key — used by the music-generation room only. Leave unset if
# you don't use music. https://kie.ai
# KIE_API_KEY=

# Hide englyph memory/source tools from the agent's tool surface. The
# pre-inference memory pack still runs and feeds context normally;
# useful for measuring how much the agent leans on tool calls vs the
# injected pack.
# MANTLE_DISABLE_MEMORY_TOOLS=1
